{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:best-practices",
        ":prHourlyLimitNone",
        ":label(dependencies)"
    ],
    "ignorePresets": [
        ":ignoreModulesAndTests"
    ],
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "semanticCommitType": "ci"
        }
    ]
}
